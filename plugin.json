{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-git-core",
  "name": {
    "ko": "git \ub77c\uc774\ube0c\ub7ec\ub9ac",
    "en": "Git library"
  },
  "version": "0.0.1",
  "description": {
    "ko": "git \uc2e4\ud589 \uaddc\uc57d\uacfc \uc800\uc7a5\uc18c \ud504\ub9ac\ubbf8\ud2f0\ube0c\uc758 \ub2e8\uc77c\uc9c4\uc2e4. \ubc1c\uacac(root)\u00b7init\u00b7clone, porcelain v2 status \uc640 git.changed \ubcc0\uacbd \uc774\ubca4\ud2b8, worktree \ud504\ub9ac\ubbf8\ud2f0\ube0c, stage/commit/discard \ub97c \ucee4\ub9e8\ub4dc\ub85c \ub178\ucd9c\ud569\ub2c8\ub2e4.",
    "en": "Single truth for the git execution convention and repository primitives. Exposes discovery (root), init, clone, porcelain v2 status with git.changed events, worktree primitives, and stage/commit/discard as commands."
  },
  "entry": "main.js",
  "permissions": [
    "commands",
    "commands:destructive",
    "process",
    "fs:read"
  ],
  "implements": [
    {
      "id": "soksak-spec-plugin-git",
      "version": "0.0.1"
    }
  ],
  "contributes": {
    "commands": [
      {
        "name": "root",
        "title": {
          "ko": "\uc800\uc7a5\uc18c \ud310\ubcc4",
          "en": "Locate repository root"
        }
      },
      {
        "name": "head",
        "title": {
          "ko": "\ud604\uc7ac \ube0c\ub79c\uce58 \ud655\uc778",
          "en": "Read the checked-out branch"
        }
      },
      {
        "name": "init",
        "title": {
          "ko": "\uc800\uc7a5\uc18c \ucd08\uae30\ud654",
          "en": "Initialize a repository"
        }
      },
      {
        "name": "clone",
        "title": {
          "ko": "\uc800\uc7a5\uc18c \ubcf5\uc81c",
          "en": "Clone a repository"
        }
      },
      {
        "name": "status",
        "title": {
          "ko": "\uc800\uc7a5\uc18c \uc0c1\ud0dc \uc870\ud68c",
          "en": "Read repository status"
        }
      },
      {
        "name": "log",
        "title": {
          "ko": "\ucee4\ubc0b \uc774\ub825 \uc870\ud68c",
          "en": "Read the commit log"
        }
      },
      {
        "name": "show",
        "title": {
          "ko": "\ucee4\ubc0b \uc0c1\uc138 \ud655\uc778",
          "en": "Show a commit"
        }
      },
      {
        "name": "diff",
        "title": {
          "ko": "\ubcc0\uacbd \ub0b4\uc6a9 \ube44\uad50",
          "en": "Show the diff"
        }
      },
      {
        "name": "diff.files",
        "title": {
          "ko": "\ube0c\ub79c\uce58 \ubcc0\uacbd \ud30c\uc77c \ubaa9\ub85d",
          "en": "List a branch's changed files"
        }
      },
      {
        "name": "diff.range",
        "title": {
          "ko": "\ube0c\ub79c\uce58 \ubcc0\uacbd \ub0b4\uc6a9 \ube44\uad50",
          "en": "Show a branch's diff"
        }
      },
      {
        "name": "branch.exists",
        "title": {
          "ko": "\ube0c\ub79c\uce58 \uc874\uc7ac \ud655\uc778",
          "en": "Check a branch exists"
        }
      },
      {
        "name": "watch.start",
        "title": {
          "ko": "\ubcc0\uacbd \uac10\uc2dc \uc2dc\uc791",
          "en": "Start change watch"
        }
      },
      {
        "name": "watch.stop",
        "title": {
          "ko": "\ubcc0\uacbd \uac10\uc2dc \uc911\uc9c0",
          "en": "Stop change watch"
        }
      },
      {
        "name": "watch.list",
        "title": {
          "ko": "\ubcc0\uacbd \uac10\uc2dc \ubaa9\ub85d",
          "en": "List change watches"
        }
      },
      {
        "name": "worktree.add",
        "title": {
          "ko": "\uc6cc\ud06c\ud2b8\ub9ac \ucd94\uac00",
          "en": "Add a worktree"
        }
      },
      {
        "name": "worktree.list",
        "title": {
          "ko": "\uc6cc\ud06c\ud2b8\ub9ac \ubaa9\ub85d",
          "en": "List worktrees"
        }
      },
      {
        "name": "worktree.remove",
        "title": {
          "ko": "\uc6cc\ud06c\ud2b8\ub9ac \uc81c\uac70",
          "en": "Remove a worktree"
        }
      },
      {
        "name": "worktree.remove.force",
        "title": {
          "ko": "\uc6cc\ud06c\ud2b8\ub9ac \uac15\uc81c \uc81c\uac70",
          "en": "Force-remove a worktree"
        },
        "danger": "destructive"
      },
      {
        "name": "worktree.prune",
        "title": {
          "ko": "\uc6cc\ud06c\ud2b8\ub9ac \uc815\ub9ac",
          "en": "Prune worktrees"
        }
      },
      {
        "name": "stage",
        "title": {
          "ko": "\ubcc0\uacbd \uc2a4\ud14c\uc774\uc9c0",
          "en": "Stage changes"
        },
        "danger": "destructive"
      },
      {
        "name": "unstage",
        "title": {
          "ko": "\uc2a4\ud14c\uc774\uc9c0 \ud574\uc81c",
          "en": "Unstage changes"
        },
        "danger": "destructive"
      },
      {
        "name": "commit",
        "title": {
          "ko": "\ucee4\ubc0b \uc0dd\uc131",
          "en": "Create a commit"
        },
        "danger": "destructive"
      },
      {
        "name": "discard",
        "title": {
          "ko": "\ubcc0\uacbd \ud30c\uae30",
          "en": "Discard changes"
        },
        "danger": "destructive"
      },
      {
        "name": "merge",
        "title": {
          "ko": "\ube0c\ub79c\uce58 \uba38\uc9c0",
          "en": "Merge a branch"
        },
        "danger": "destructive"
      }
    ],
    "events": [
      "git.changed"
    ]
  }
}
